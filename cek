<!DOCTYPE html>
<html>
<head>
  <title>Random Prompt</title>
</head>
<body>

<h2>Random Prompt Generator</h2>
<p id="output">Klik tombol untuk mulai</p>

<button onclick="generatePrompt()">Generate</button>

<script>
const prompts = [
  "Buat landing page untuk toko kopi",
  "Desain website portfolio minimalis",
  "Buat UI aplikasi cuaca modern",
  "Landing page produk sepatu",
  "Website restoran dengan menu interaktif",
  "Dashboard admin sederhana"
];

function generatePrompt() {
  const random = prompts[Math.floor(Math.random() * prompts.length)];
  document.getElementById("output").innerText = random;
}
</script>

</body>
</html>
